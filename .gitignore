###############################################################################
# LabVIEW — compiled code, cache, and user files
###############################################################################

# Compiled object cache (auto-generated by LabVIEW)
*.lvscache
*.lvuser
LVCompiledCache/
**/LVCompiledCache/

# Per-user LabVIEW project settings
*.lvproj.user

# Backup and autosave files
*.vi~
*.ctl~
*.lvproj~

# Temp / intermediate
*.tmp
*.bak
*.old
*.orig

###############################################################################
# LabVIEW build outputs
###############################################################################

# Executables and shared libraries
*.exe
*.dll
*.so
*.dylib

# Installers and archives
*.msi
*.zip
*.tar
*.tar.gz
*.iso

# Common build folders
Builds/
build/
dist/

###############################################################################
# TestStand — user, cache, and runtime-generated files
###############################################################################

# Per-user TestStand settings
*.tsu        # TestStand User files
*.tslock     # Sequence editor lock files

# TestStand temporary and cache files
*.tmp
*.log
TestStand/Cache/
**/TestStand/Cache/

# Batch model / execution artifacts
*.html       # Auto-generated reports (if not versioned)
*.xml        # Reports/results (remove if you version report templates or limits)
Reports/
TestResults/
Results/
**/Modules/    # Compiled TestStand modules
**/Modules/**

###############################################################################
# TestStand Deployment / Build artifacts
###############################################################################

# Deployment Utility outputs
Deployment/
Installer/
Distribution/
**/ProcessingStage/
**/Packages/

###############################################################################
# NI / Tooling folders
###############################################################################

# NI Package Manager / tooling
.nipkg/
.npmi/

# LabVIEW NXG (if ever present)
*.gvi
.gcomp/

###############################################################################
# OS-specific junk
###############################################################################

# Windows
Thumbs.db
Desktop.ini

# macOS
.DS_Store

# Linux
*~

###############################################################################
# Logs
###############################################################################

logs/
*.log